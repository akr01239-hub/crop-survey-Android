<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="8dp" app:cardCornerRadius="10dp" app:cardElevation="2dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tv_item_type" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:textColor="#0F172A"/>
            <TextView android:id="@+id/tv_survey_id" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="12sp" android:textColor="#64748B" android:fontFamily="monospace"/>
            <TextView android:id="@+id/tv_queued_at" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="11sp" android:textColor="#64748B"/>
        </LinearLayout>
        <TextView android:id="@+id/tv_retry_count" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="12sp" android:textColor="#D97706"
            android:background="#FFFBEB" android:paddingStart="8dp" android:paddingEnd="8dp"
            android:paddingTop="4dp" android:paddingBottom="4dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
