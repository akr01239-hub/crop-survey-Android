<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7F0"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp"
            android:src="@drawable/logo"
            android:contentDescription="Logo"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/farmer_verification"
            android:textSize="13sp"
            android:textColor="#4CAF50"
            android:layout_marginBottom="16dp"/>

        <!-- STEP 1: Yes / No — always visible -->
        <androidx.cardview.widget.CardView
            android:id="@+id/layout_step1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌾"
                        android:textSize="18sp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/verify_farmer_title"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"/>

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/verify_farmer_subtitle"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btn_no"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="@string/skip_verification"
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:backgroundTint="#EEEEEE"
                        style="@style/Widget.MaterialComponents.Button"/>

                    <Button
                        android:id="@+id/btn_yes"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="@string/verify_farmer"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2E7D32"
                        style="@style/Widget.MaterialComponents.Button"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- STEP 2: Phone input — appears below after clicking Verify -->
        <androidx.cardview.widget.CardView
            android:id="@+id/layout_step2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/farmers_mobile_label"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"/>

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/farmers_mobile_hint"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="10dp"/>

                <!-- Phone row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:background="@drawable/input_bg"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="+91"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp"/>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center_vertical"
                        android:background="#DDDDDD"/>

                    <EditText
                        android:id="@+id/et_farmer_phone"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="10-digit mobile number"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:textSize="14sp"
                        android:paddingStart="10dp"
                        android:background="@null"
                        android:textColor="#1A1A1A"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_phone_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#DC2626"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp"
                    android:visibility="gone"/>

                <ProgressBar
                    android:id="@+id/progress_send"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone"/>

                <Button
                    android:id="@+id/btn_send_otp"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="@string/send_otp"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2E7D32"
                    style="@style/Widget.MaterialComponents.Button"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- STEP 3: OTP input — appears below after OTP sent -->
        <androidx.cardview.widget.CardView
            android:id="@+id/layout_step3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔐"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tv_otp_sent_to"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/enter_otp"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"/>

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/otp_section_hint"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/et_otp"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Enter 6-digit OTP"
                    android:inputType="numberPassword"
                    android:maxLength="6"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:letterSpacing="0.3"
                    android:textColor="#1A1A1A"
                    android:background="@drawable/input_bg"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tv_otp_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#DC2626"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tv_resend_timer"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#999999"
                        android:textSize="11sp"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/btn_resend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/resend_otp"
                        android:textColor="#2E7D32"
                        android:textSize="12sp"
                        android:padding="4dp"
                        android:visibility="gone"/>

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progress_verify"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone"/>

                <Button
                    android:id="@+id/btn_verify_otp"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="@string/verify_and_start"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2E7D32"
                    style="@style/Widget.MaterialComponents.Button"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>