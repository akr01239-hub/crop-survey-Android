<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_chm_buffer_check.xml
  Shown for CHM Visit 2+ instead of PolygonMapActivity.
  Displays the existing polygon on the map, tracks live GPS,
  and unlocks the survey flow once the user is inside the 50 m buffer.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Full-screen map (existing polygon rendered on top) -->
    <FrameLayout
        android:id="@+id/map_fragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_card"/>

    <!-- ── Top bar ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:background="#CC000000"
        android:padding="14dp"
        android:paddingTop="44dp"
        android:gravity="center_vertical">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#FFFFFF"
            android:contentDescription="Back"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tv_visit_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHM — Visit 2"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_case_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Case: —"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- CHM badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CHM"
            android:background="#1D4ED8"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"/>
    </LinearLayout>

    <!-- ── Distance pill floating over map ────────────────────────────── -->
    <TextView
        android:id="@+id/tv_distance_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_above="@+id/bottom_card"
        android:layout_marginBottom="12dp"
        android:background="#CC0F172A"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:text="📍 Acquiring GPS…"
        android:visibility="visible"/>

    <!-- ── Bottom card ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/bottom_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="20dp"
        android:paddingBottom="36dp">

        <!-- ── State A: Outside buffer ──────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layout_outside_buffer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Red warning strip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFF1F2"
                android:padding="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️"
                    android:textSize="20sp"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Outside Survey Boundary"
                        android:textColor="#BE123C"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_distance_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Move closer to the field to start the survey."
                        android:textColor="#9F1239"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The blue polygon shows the previously drawn field boundary. Walk to within 50 m of the boundary to unlock the survey."
                android:textColor="#64748B"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="14dp"/>

            <Button
                android:id="@+id/btn_start_survey_locked"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔒  Move Into Boundary to Continue"
                android:backgroundTint="#94A3B8"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:enabled="false"/>
        </LinearLayout>

        <!-- ── State B: Inside buffer ────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layout_inside_buffer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Green success strip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F0FDF4"
                android:padding="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="20sp"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="You are within the survey boundary!"
                        android:textColor="#15803D"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPS confirmed — you can proceed with this visit."
                        android:textColor="#166534"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btn_start_survey"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="▶  Start Visit Survey →"
                android:backgroundTint="#16A34A"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone"/>

</RelativeLayout>
