    <string name="guide_step5_title">📝 सर्वेक्षण फॉर्म भरा</string>
    <string name="guide_step5_msg">फॉर्ममध्ये अनेक विभाग आहेत। * चिन्हित सर्व अनिवार्य फील्ड भरा।\n\nदर 15 सेकंदांनी प्रगती आपोआप सेव्ह होते।</string>
    <string name="guide_step5_tip">💡 सूचना: कधीही \'Save Draft\' दाबा आणि नंतर परत या।</string>
    <string name="guide_step5_action">समजले →</string>
