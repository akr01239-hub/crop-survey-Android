    <!-- ONBOARDING SLIDES -->
    <string name="guide_slide1_title">কৃষি সৰ্বেক্ষণত আপোনাক স্বাগতম</string>
    <string name="guide_slide1_body">এই চমু গাইডে আপোনাক ক\'ব যে এপটো কেনেকৈ কাম কৰে, কি অনুমোদিত আৰু প্ৰথম সৰ্বেক্ষণ কেনেকৈ সঠিকভাৱে সম্পন্ন কৰিব।\n\nপ্ৰতিটো পৃষ্ঠা মনোযোগেৰে পঢ়ক — ২ মিনিটতকৈ কম সময় লাগিব।</string>
    <string name="guide_slide2_title">এটা একাউণ্ট — এটা ডিভাইছ</string>
    <string name="guide_slide2_body">⚠️ আপোনাৰ একাউণ্ট প্ৰথম ডিভাইছত লক হয়।\n\n• দ্বিতীয় ডিভাইছত লগইন কৰিলে প্ৰথমটো লগআউট হ\'ব।\n• একে সময়তে ২টা ডিভাইছ ব্যৱহাৰ নহ\'ব।\n• ফোন সলনি কৰিলে Admin-ৰ পৰা একাউণ্ট আনলক কৰক।</string>
    <string name="guide_slide3_title">নকল GPS ব্যৱহাৰ নকৰিব</string>
    <string name="guide_slide3_body">এপটোৱে নকল লোকেচন ধৰা পেলায়।\n\n• নকল লোকেচন পালে এপটো লগে লগে বন্ধ হ\'ব।\n• নকল GPS থকা সৰ্বেক্ষণ বাতিল হ\'ব।\n\nসদায় প্ৰকৃত পথাৰলৈ গৈ সৰ্বেক্ষণ আৰম্ভ কৰক।</string>
    <string name="guide_slide4_title">সৰ্বেক্ষণৰ প্ৰকাৰ</string>
    <string name="guide_slide4_body">এপত ৩টা সৰ্বেক্ষণ প্ৰকাৰ আছে:\n\n🟢  CLS — শস্য ক্ষতি সৰ্বেক্ষণ\n🔵  CHM — শস্য স্বাস্থ্য নিৰীক্ষণ\n🟠  CCE — শস্য কাটনি পৰীক্ষা</string>
    <string name="guide_slide5_title">ফটো গুৰুত্বপূৰ্ণ</string>
    <string name="guide_slide5_body">প্ৰতিটো সৰ্বেক্ষণত প্ৰয়োজনীয় আৰু ঐচ্ছিক ফটো থাকে।\n\n• জমা দিয়াৰ আগতে সকলো প্ৰয়োজনীয় ফটো তুলিব লাগিব।\n• ফটো স্বয়ংক্ৰিয়ভাৱে GPS টেগ হয়।</string>
    <string name="guide_slide6_title">খচৰা → জমা → অনুমোদন</string>
    <string name="guide_slide6_body">সৰ্বেক্ষণ এনেকৈ সম্পন্ন হয়:\n\n1️⃣  ফৰ্ম পূৰণ + ফটো তোলক\n2️⃣  Save Draft টিপক\n3️⃣  সাজু হ\'লে Submit টিপক\n4️⃣  QC পৰ্যালোচনালৈ যায়\n5️⃣  Approved ✅ বা Rejected ❌</string>
    <string name="guide_slide6_btn">বুজিলোঁ! আৰম্ভ কৰোঁ</string>

    <!-- STEP OVERLAYS -->
    <string name="guide_step0_title">👋 নমস্কাৰ! মই আপোনাৰ AI সৰ্বেক্ষণ গাইড</string>
    <string name="guide_step0_msg">মই আপোনাক প্ৰথম সৰ্বেক্ষণ আৰম্ভৰ পৰা শেষলৈকে সম্পন্ন কৰাত সহায় কৰিম।\n\nএই স্ক্ৰীনত ৩টা সৰ্বেক্ষণ প্ৰকাৰ আছে: CLS, CHM আৰু CCE।</string>
    <string name="guide_step0_tip">💡 পৰামৰ্শ: CLS = শস্য ক্ষতি সৰ্বেক্ষণ। প্ৰথমবাৰ CLS-ৰ পৰা আৰম্ভ কৰক।</string>
    <string name="guide_step0_action">CLS-ৰ পৰা আৰম্ভ কৰক →</string>
    <string name="guide_step1_title">📋 সৰ্বেক্ষণৰ প্ৰকাৰ বাছক</string>
    <string name="guide_step1_msg">শস্য ক্ষতি সৰ্বেক্ষণ আৰম্ভ কৰিবলৈ CLS কাৰ্ডত টিপক।</string>
    <string name="guide_step1_tip">💡 পৰামৰ্শ: তিনিওটা প্ৰকাৰৰ একেই ক্ৰম — ফৰ্ম + ফটো + জমা।</string>
    <string name="guide_step1_action">বুজিলোঁ →</string>
    <string name="guide_step2_title">👨‍🌾 কৃষক যাচাই</string>
    <string name="guide_step2_msg">মোবাইল নম্বৰ আৰু OTP-ৰে কৃষকৰ পৰিচয় যাচাই কৰক।\n\nকৃষক নাথাকিলে SKIP টিপক।</string>
    <string name="guide_step2_tip">💡 পৰামৰ্শ: যাচাই কৰা সৰ্বেক্ষণ দ্ৰুতভাৱে প্ৰক্ৰিয়া হয়।</string>
    <string name="guide_step2_action">বুজিলোঁ →</string>
    <string name="guide_step3_title">✅ বহুত ভাল! কৃষক যাচাই হৈছে</string>
    <string name="guide_step3_msg">কৃষকৰ ফোন নিশ্চিত হৈছে।</string>
    <string name="guide_step3_tip">💡 পৰামৰ্শ: জমা দিয়াৰ আগতেও যাচাই কৰিব পাৰি।</string>
    <string name="guide_step3_action">বুজিলোঁ →</string>
    <string name="guide_step4_title">🗺️ পথাৰৰ সীমা আঁকক</string>
    <string name="guide_step4_msg">পথাৰৰ সীমাৰ চাৰিওকাষে কমেও ৩টা বিন্দু যোগ কৰিবলৈ মানচিত্ৰত টিপক।\n\nপ্ৰকৃত পথাৰৰ স্থানত থাকক — GPS সঠিকতা গুৰুত্বপূৰ্ণ!</string>
    <string name="guide_step4_tip">💡 পৰামৰ্শ: ভুল হ\'লে DELETE টিপি পুনৰ আৰম্ভ কৰক।</string>
    <string name="guide_step4_action">বুজিলোঁ →</string>
    <string name="guide_step5_title">📝 সৰ্বেক্ষণ ফৰ্ম পূৰণ কৰক</string>
    <string name="guide_step5_msg">ফৰ্মত কেইবাটাও অংশ আছে। * চিহ্নিত সকলো বাধ্যতামূলক ক্ষেত্ৰ পূৰণ কৰক।</string>
    <string name="guide_step5_tip">💡 পৰামৰ্শ: যিকোনো সময়তে \'Save Draft\' টিপিব পাৰি।</string>
    <string name="guide_step5_action">বুজিলোঁ →</string>
    <string name="guide_step6_title">📅 মূল তথ্য অংশ</string>
    <string name="guide_step6_msg">পূৰণ কৰক:\n• বছৰ\n• ঋতু (খাৰিফ / ৰবি / জায়দ)\n• আঁচনি</string>
    <string name="guide_step6_tip">💡 পৰামৰ্শ: বছৰ বৰ্তমান তাৰিখ অনুযায়ী স্বয়ংক্ৰিয়ভাৱে পূৰণ হয়।</string>
    <string name="guide_step6_action">বুজিলোঁ →</string>
    <string name="guide_step7_title">📍 স্থান অংশ</string>
    <string name="guide_step7_msg">ৰাজ্য → জিলা → তহচিল → গাঁও বাছক।</string>
    <string name="guide_step7_tip">💡 পৰামৰ্শ: গাঁও নাপালে Gram Panchayat ক্ষেত্ৰত নিজে লিখক।</string>
    <string name="guide_step7_action">বুজিলোঁ →</string>
    <string name="guide_step8_title">🌾 শস্যৰ বিৱৰণ অংশ</string>
    <string name="guide_step8_msg">শস্যৰ প্ৰকাৰ, জাত, অৱস্থা আৰু জলসিঞ্চনৰ প্ৰকাৰ বাছক।</string>
    <string name="guide_step8_tip">💡 পৰামৰ্শ: শস্য বৰ্তমান যি অৱস্থাত আছে সেইটো বাছক।</string>
    <string name="guide_step8_action">বুজিলোঁ →</string>
    <string name="guide_step9_title">📸 এতিয়া ফটোৰ পালি</string>
    <string name="guide_step9_msg">ওপৰত PHOTOS টেবত টিপক। Required ✦ ফটো জমা দিয়াৰ আগতে তুলিব লাগিব।</string>
    <string name="guide_step9_tip">💡 পৰামৰ্শ: ফটো স্বয়ংক্ৰিয়ভাৱে GPS টেগ হয়।</string>
    <string name="guide_step9_action">বুজিলোঁ →</string>
    <string name="guide_step10_title">📷 প্ৰয়োজনীয় ফটো তোলক</string>
    <string name="guide_step10_msg">প্ৰতিটো স্লটৰ কাষত CAPTURE টিপক।</string>
    <string name="guide_step10_tip">💡 পৰামৰ্শ: ফটো অস্পষ্ট হ\'লে লগে লগে RETAKE টিপক।</string>
    <string name="guide_step10_action">বুজিলোঁ →</string>
    <string name="guide_step11_title">💾 খচৰা সংৰক্ষণ কৰক</string>
    <string name="guide_step11_msg">SAVE DRAFT টিপক।\n• পিছত অব্যাহত ৰাখিব পাৰি\n• ডেটা নষ্ট নহ\'ব</string>
    <string name="guide_step11_tip">💡 পৰামৰ্শ: দুৰ্বল নেটৱৰ্কত নিজে সংৰক্ষণ কৰাটো ভাল।</string>
    <string name="guide_step11_action">বুজিলোঁ →</string>
    <string name="guide_step12_title">🎉 জমা দিবলৈ সাজু!</string>
