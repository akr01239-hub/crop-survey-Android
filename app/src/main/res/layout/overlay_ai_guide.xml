<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Semi-transparent dim layer (tap-through) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#55000000"/>

    <!-- Coach card anchored to bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#1F2937"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:elevation="16dp">

        <!-- Top row: progress + close -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- Robot icon + progress -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖"
                    android:textSize="18sp"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tv_guide_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 1 / 13"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Close X -->
            <ImageButton
                android:id="@+id/btn_guide_close"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close_white"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:contentDescription="Close guide"/>
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tv_guide_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#F9FAFB"
            android:layout_marginBottom="8dp"/>

        <!-- Message -->
        <TextView
            android:id="@+id/tv_guide_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#D1D5DB"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="10dp"/>

        <!-- Tip -->
        <TextView
            android:id="@+id/tv_guide_tip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#6EE7B7"
            android:background="#0D3B2E"
            android:padding="10dp"
            android:layout_marginBottom="12dp"/>

        <!-- Action button -->
        <Button
            android:id="@+id/btn_guide_action"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="Got it →"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#16A34A"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <!-- Turn off guide link -->
        <TextView
            android:id="@+id/tv_guide_disable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Turn off guide"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:padding="4dp"/>

    </LinearLayout>
</FrameLayout>
