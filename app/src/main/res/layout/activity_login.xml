<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F0FDF4" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp" android:gravity="center_horizontal">

        <!-- Language Button (top right) -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">
            <TextView
                android:id="@+id/btn_change_language"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="🌐 Language"
                android:textColor="#16A34A"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="#E8F5E9"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:clickable="true"
                android:focusable="true"/>
        </FrameLayout>

        <!-- Logo -->
        <ImageView
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_marginTop="24dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Krishi Sarvekshan" android:textSize="24sp" android:textStyle="bold"
            android:textColor="#052E16" android:layout_marginTop="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Field Survey Platform" android:textSize="13sp" android:textColor="#4B7A5A"
            android:layout_marginTop="4dp" android:layout_marginBottom="28dp"/>

        <!-- Card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="20dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardCornerRadius="14dp" app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="24dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/login_title" android:textSize="17sp" android:textStyle="bold"
                    android:textColor="#052E16" android:layout_marginBottom="20dp"/>

                <!-- Error -->
                <TextView android:id="@+id/tv_error" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:background="#FEF2F2"
                    android:padding="12dp" android:textColor="#DC2626" android:textSize="13sp"
                    android:layout_marginBottom="12dp" android:visibility="gone"/>

                <!-- Phone -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/phone_number" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="#052E16" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/et_phone" android:layout_width="match_parent"
                    android:layout_height="50dp" android:hint="+91 10-digit number"
                    android:inputType="phone" android:background="@drawable/input_background"
                    android:padding="14dp" android:layout_marginBottom="16dp"
                    android:textColor="#0F172A" android:textColorHint="#94A3B8"/>

                <!-- Password -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/password" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="#052E16" android:layout_marginBottom="6dp"/>
                <RelativeLayout android:layout_width="match_parent" android:layout_height="50dp"
                    android:layout_marginBottom="8dp">
                    <EditText android:id="@+id/et_password" android:layout_width="match_parent"
                        android:layout_height="match_parent" android:hint="Your password"
                        android:inputType="textPassword" android:background="@drawable/input_background"
                        android:padding="14dp" android:paddingEnd="60dp"
                        android:textColor="#0F172A" android:textColorHint="#94A3B8"/>
                    <TextView android:id="@+id/btn_show_password" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Show"
                        android:textColor="#16A34A" android:textStyle="bold" android:textSize="13sp"
                        android:layout_alignParentEnd="true" android:layout_centerVertical="true"
                        android:paddingEnd="14dp" android:clickable="true" android:focusable="true"/>
                </RelativeLayout>

                <!-- Forgot password -->
                <TextView android:id="@+id/btn_forgot_password" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="@string/forgot_password"
                    android:textColor="#16A34A" android:textSize="13sp" android:textStyle="bold"
                    android:layout_gravity="end" android:layout_marginBottom="20dp"
                    android:clickable="true" android:focusable="true"/>

                <ProgressBar android:id="@+id/progress_bar" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_gravity="center"
                    android:visibility="gone" android:layout_marginBottom="8dp"/>

                <Button android:id="@+id/btn_login" android:layout_width="match_parent"
                    android:layout_height="52dp" android:text="@string/login_btn"
                    android:backgroundTint="#16A34A" android:textColor="#FFFFFF"
                    android:textSize="15sp" android:textStyle="bold"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sign up link -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/new_surveyor" android:textColor="#4B7A5A" android:textSize="14sp"/>
            <TextView android:id="@+id/btn_signup" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="@string/request_account"
                android:textColor="#16A34A" android:textSize="14sp" android:textStyle="bold"
                android:clickable="true" android:focusable="true"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Powered by Krishi Care &amp; Management Services Pvt. Ltd"
            android:textSize="11sp" android:textColor="#86EFAC" android:layout_marginTop="28dp"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>