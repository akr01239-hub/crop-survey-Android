<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F1F5FF">

    <!-- ═══ HERO HEADER ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#14532D"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="30dp">

        <!-- Greeting + icons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good morning,"
                    android:textSize="13sp"
                    android:textColor="#86EFAC"/>
                <TextView
                    android:id="@+id/tv_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AKSHAY"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <RelativeLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginEnd="10dp">
                <ImageButton
                    android:id="@+id/btn_queue"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_icon_glass"
                    android:src="@drawable/ic_bell"
                    android:tint="#FFFFFF"
                    android:contentDescription="Notifications"
                    android:padding="10dp"/>
                <TextView
                    android:id="@+id/tv_queue_badge"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="@drawable/bg_badge_red"
                    android:textColor="#FFFFFF"
                    android:textSize="8sp"
                    android:gravity="center"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:visibility="gone"
                    android:text="0"/>
            </RelativeLayout>

            <ImageButton
                android:id="@+id/btn_ai_guide"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_glass"
                android:src="@drawable/ic_language"
                android:tint="#FCD34D"
                android:contentDescription="AI Guide"
                android:padding="10dp"
                android:layout_marginEnd="8dp"/>

            <ImageButton
                android:id="@+id/btn_change_language"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_glass"
                android:src="@drawable/ic_language"
                android:tint="#FFFFFF"
                android:contentDescription="Change Language"
                android:padding="10dp"
                android:layout_marginEnd="8dp"/>

            <ImageButton
                android:id="@+id/btn_logout"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_glass"
                android:src="@drawable/ic_logout"
                android:tint="#FFFFFF"
                android:contentDescription="Logout"
                android:padding="10dp"/>
        </LinearLayout>

        <!-- 4 stat boxes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/tv_stat_submitted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_submitted"
                    android:textSize="9sp"
                    android:textColor="#86EFAC"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/tv_stat_draft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_draft"
                    android:textSize="9sp"
                    android:textColor="#86EFAC"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/tv_stat_approved"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#4ADE80"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_approved"
                    android:textSize="9sp"
                    android:textColor="#86EFAC"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card">
                <TextView
                    android:id="@+id/tv_stat_rejected"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FB7185"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_rejected"
                    android:textSize="9sp"
                    android:textColor="#FCA5A5"
                    android:gravity="center"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- ═══ WHITE SCROLLABLE BODY ═══ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F0FDF4"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingBottom="80dp">

            <!-- START A SURVEY label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/start_survey"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="12dp"/>

            <!-- Survey type cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="24dp">

                <!-- CLS -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_cls"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="2dp"
                    app:strokeColor="#BBF7D0">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:background="#16A34A"
                            android:layout_marginBottom="12dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CLS"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#15803D"
                            android:gravity="center"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Crop Loss"
                            android:textSize="11sp"
                            android:textColor="#6B7280"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CHM -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_chm"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="2dp"
                    app:strokeColor="#A7F3D0">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:background="#059669"
                            android:layout_marginBottom="12dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CHM"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#059669"
                            android:gravity="center"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Health Mon."
                            android:textSize="11sp"
                            android:textColor="#6B7280"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CCE -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_cce"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="2dp"
                    app:strokeColor="#FDE68A">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:background="#D97706"
                            android:layout_marginBottom="12dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CCE"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#D97706"
                            android:gravity="center"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Crop Cutting"
                            android:textSize="11sp"
                            android:textColor="#6B7280"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- MY SURVEYS label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/my_tasks"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"/>
            </LinearLayout>

            <!-- TABS - fixed full-width, not scrollable -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_tab_strip"
                android:padding="4dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tab_draft"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/tab_active"
                    android:gravity="center"
                    android:text="@string/status_draft"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/tab_submitted"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/tab_inactive"
                    android:gravity="center"
                    android:text="@string/status_submitted"
                    android:textColor="#334155"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/tab_approved"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/tab_inactive"
                    android:gravity="center"
                    android:text="@string/status_approved"
                    android:textColor="#334155"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/tab_rejected"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/tab_inactive"
                    android:gravity="center"
                    android:text="@string/status_rejected"
                    android:textColor="#334155"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

            <!-- hidden views -->
            <TextView android:id="@+id/tv_pending_count" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:visibility="gone"/>
            <TextView android:id="@+id/tv_stat_month" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:visibility="gone"/>
            <!-- Keep hidden ProgressBar so existing references don't crash -->
            <ProgressBar android:id="@+id/progress_bar" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:visibility="gone"/>

            <!-- Centered 3-dot loader with status text -->
            <LinearLayout
                android:id="@+id/layout_loading"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="14dp">
                    <View
                        android:id="@+id/dot1"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="8dp"
                        android:background="#16A34A"
                        android:alpha="0.3"/>
                    <View
                        android:id="@+id/dot2"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="8dp"
                        android:background="#16A34A"
                        android:alpha="0.3"/>
                    <View
                        android:id="@+id/dot3"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="#16A34A"
                        android:alpha="0.3"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_loading_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connecting..."
                    android:textSize="13sp"
                    android:textColor="#64748B"
                    android:gravity="center"/>
            </LinearLayout>

            <TextView android:id="@+id/tv_no_surveys"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="No surveys found." android:textColor="#94A3B8"
                android:textSize="14sp" android:gravity="center"
                android:padding="40dp" android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recent_surveys"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>