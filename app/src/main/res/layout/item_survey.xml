<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0">

    <!-- Left accent stripe -->
    <View
        android:id="@+id/view_accent"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="#2563EB"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="4dp">

        <!-- Main row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="14dp"
            android:paddingBottom="12dp"
            android:paddingEnd="14dp"
            android:gravity="center_vertical">



            <!-- Middle content -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Case ID + type pill -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="3dp">
                    <TextView
                        android:id="@+id/tv_case_id"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#94A3B8"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.04"/>
                    <TextView
                        android:id="@+id/tv_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#2563EB"
                        android:background="@drawable/bg_type_pill"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"/>
                </LinearLayout>

                <!-- Farmer name -->
                <TextView
                    android:id="@+id/tv_farmer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"
                    android:layout_marginBottom="2dp"/>

                <!-- CCE/type-specific subtitle: crop · cce_number · date -->
                <TextView
                    android:id="@+id/tv_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#475569"
                    android:layout_marginBottom="5dp"
                    android:visibility="gone"/>

                <!-- Location + status row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tv_location"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="11sp"
                        android:textColor="#94A3B8"/>
                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Chevron -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="20sp"
                android:textColor="#CBD5E1"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Rejection reason -->
        <LinearLayout
            android:id="@+id/layout_rejection_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_rejection_strip"
            android:paddingStart="12dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginEnd="0dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠ "
                android:textSize="12sp"
                android:textColor="#DC2626"/>
            <TextView
                android:id="@+id/tv_rejection_reason"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="#DC2626"/>
        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:id="@+id/layout_action_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:paddingTop="4dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_edit_draft"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="@string/btn_edit"
                android:textSize="12sp"
                android:backgroundTint="#EFF6FF"
                android:textColor="#2563EB"
                android:layout_marginEnd="8dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btn_submit_draft"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="@string/btn_submit"
                android:textSize="12sp"
                android:backgroundTint="#2563EB"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btn_delete_draft"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:text="🗑"
                android:textSize="14sp"
                android:backgroundTint="#FEF2F2"
                android:textColor="#DC2626"
                android:padding="0dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btn_edit_rejected"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:text="Re-edit &amp; Resubmit"
                android:textSize="12sp"
                android:backgroundTint="#FEF2F2"
                android:textColor="#DC2626"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>