<?xml version="1.0" encoding="utf-8"?>
<!--
  One row in the PhotoSelectionActivity recycler.
  Shows: index badge | photo title | instruction | capture button | tick
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/card_photo_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:layout_marginBottom="10dp"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:elevation="2dp">

    <!-- Index badge -->
    <TextView
        android:id="@+id/tv_photo_index"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/circle_green"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:text="1"/>

    <!-- Title + instruction -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/tv_photo_item_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:text="Photo Label"/>

        <TextView
            android:id="@+id/tv_photo_item_instruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#64748B"
            android:layout_marginTop="3dp"
            android:visibility="gone"
            android:text="Instruction text"/>
    </LinearLayout>

    <!-- Tick (shown after capture) -->
    <ImageView
        android:id="@+id/iv_tick"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/checkbox_on_background"
        android:layout_marginEnd="8dp"
        android:visibility="gone"
        android:contentDescription="Captured"/>

    <!-- Capture button -->
    <Button
        android:id="@+id/btn_capture_photo"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="Capture"
        android:backgroundTint="#16A34A"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"/>

</LinearLayout>
