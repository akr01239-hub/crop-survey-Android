<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- ══ SECTION 1: Basic Information ══ -->
        <LinearLayout android:id="@+id/section_header_1"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal" android:background="@drawable/section_header_collapsed"
            android:padding="14dp" android:gravity="center_vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/section_basic_info" android:textSize="15sp" android:textStyle="bold" android:textColor="#0F172A"/>
            <ImageView android:id="@+id/ic_check_1" android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_check_white" android:background="@drawable/circle_green"
                android:visibility="gone" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/arrow_1" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▼" android:textColor="#64748B" android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/section_body_1"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/section_card_bg"
            android:paddingLeft="12dp" android:paddingRight="12dp"
            android:paddingTop="8dp" android:paddingBottom="12dp"
            android:layout_marginBottom="12dp" android:visibility="gone">

            <TextView android:id="@+id/lbl_online_chm_id" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_experiment_id" android:textSize="12sp" android:textColor="#64748B"
                android:layout_marginTop="8dp" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_online_chm_id" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_online_chm_id" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="Enter CHM ID" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_year" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_year" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_sp_year" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <Spinner android:id="@+id/sp_year" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:paddingLeft="12dp" android:paddingRight="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_season" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_season" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_sp_season" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <Spinner android:id="@+id/sp_season" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:paddingLeft="12dp" android:paddingRight="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_scheme" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_scheme" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_sp_scheme" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <Spinner android:id="@+id/sp_scheme" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:paddingLeft="12dp" android:paddingRight="12dp"/>
            </FrameLayout>

            <LinearLayout android:id="@+id/layout_other_scheme" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <TextView android:id="@+id/lbl_other_scheme" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/field_other_scheme" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
                <FrameLayout android:id="@+id/frame_et_other_scheme" android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                    <EditText android:id="@+id/et_other_scheme" android:layout_width="match_parent" android:layout_height="match_parent"
                        android:background="@android:color/transparent" android:hint="Specify scheme" android:padding="12dp"/>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ SECTION 2: Location ══ -->
        <LinearLayout android:id="@+id/section_header_2"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal" android:background="@drawable/section_header_collapsed"
            android:padding="14dp" android:gravity="center_vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/section_location" android:textSize="15sp" android:textStyle="bold" android:textColor="#0F172A"/>
            <ImageView android:id="@+id/ic_check_2" android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_check_white" android:background="@drawable/circle_green"
                android:visibility="gone" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/arrow_2" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▼" android:textColor="#64748B" android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/section_body_2"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/section_card_bg"
            android:paddingLeft="12dp" android:paddingRight="12dp"
            android:paddingTop="8dp" android:paddingBottom="12dp"
            android:layout_marginBottom="12dp" android:visibility="gone">

            <TextView android:id="@+id/lbl_state" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_state" android:textSize="12sp" android:textColor="#64748B"
                android:layout_marginTop="8dp" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_sp_state" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <Spinner android:id="@+id/sp_state" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:paddingLeft="12dp" android:paddingRight="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_district" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_district" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_sp_district" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <Spinner android:id="@+id/sp_district" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:paddingLeft="12dp" android:paddingRight="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_tehsil" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_tehsil" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_sp_tehsil" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <Spinner android:id="@+id/sp_tehsil" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:paddingLeft="12dp" android:paddingRight="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_revenue_circle" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_revenue_circle" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_revenue_circle" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_revenue_circle" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="Enter revenue circle" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_gram_panchayat" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_gram_panchayat" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_gram_panchayat" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_gram_panchayat" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="Enter gram panchayat" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_village" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_village" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_village" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background">
                <EditText android:id="@+id/et_village" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="Enter village name" android:padding="12dp"/>
            </FrameLayout>
        </LinearLayout>

        <!-- ══ SECTION 3: Crop Details ══ -->
        <LinearLayout android:id="@+id/section_header_3"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal" android:background="@drawable/section_header_collapsed"
            android:padding="14dp" android:gravity="center_vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/section_crop_details" android:textSize="15sp" android:textStyle="bold" android:textColor="#0F172A"/>
            <ImageView android:id="@+id/ic_check_3" android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_check_white" android:background="@drawable/circle_green"
                android:visibility="gone" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/arrow_3" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▼" android:textColor="#64748B" android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/section_body_3"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/section_card_bg"
            android:paddingLeft="12dp" android:paddingRight="12dp"
            android:paddingTop="8dp" android:paddingBottom="12dp"
            android:layout_marginBottom="12dp" android:visibility="gone">

            <TextView android:id="@+id/lbl_crop_name" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_crop_name" android:textSize="12sp" android:textColor="#64748B"
                android:layout_marginTop="8dp" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_sp_crop_name" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <Spinner android:id="@+id/sp_crop_name" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:paddingLeft="12dp" android:paddingRight="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_insurance_unit" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_insurance_unit" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_sp_insurance_unit" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <Spinner android:id="@+id/sp_insurance_unit" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:paddingLeft="12dp" android:paddingRight="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_crop_variety" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_crop_variety" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_crop_variety" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_crop_variety" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="Enter variety name" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_crop_stage" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_crop_stage" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_sp_crop_stage" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <Spinner android:id="@+id/sp_crop_stage" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:paddingLeft="12dp" android:paddingRight="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_crop_health" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_crop_condition" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_sp_crop_health" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <Spinner android:id="@+id/sp_crop_health" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:paddingLeft="12dp" android:paddingRight="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_crop_cover" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_insured_area" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_crop_cover" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_crop_cover" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="e.g. 85" android:inputType="numberDecimal" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_sowing_method" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_sampling_method" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_sp_sowing_method" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <Spinner android:id="@+id/sp_sowing_method" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:paddingLeft="12dp" android:paddingRight="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_irrigation_type" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_irrigation_type" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_sp_irrigation_type" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <Spinner android:id="@+id/sp_irrigation_type" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:paddingLeft="12dp" android:paddingRight="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_land_type" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_land_type" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_sp_land_type" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background">
                <Spinner android:id="@+id/sp_land_type" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:paddingLeft="12dp" android:paddingRight="12dp"/>
            </FrameLayout>
        </LinearLayout>

        <!-- ══ SECTION 4: Farmer Information ══ -->
        <LinearLayout android:id="@+id/section_header_4"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal" android:background="@drawable/section_header_collapsed"
            android:padding="14dp" android:gravity="center_vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/section_farmer_info" android:textSize="15sp" android:textStyle="bold" android:textColor="#0F172A"/>
            <ImageView android:id="@+id/ic_check_4" android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_check_white" android:background="@drawable/circle_green"
                android:visibility="gone" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/arrow_4" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▼" android:textColor="#64748B" android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/section_body_4"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/section_card_bg"
            android:paddingLeft="12dp" android:paddingRight="12dp"
            android:paddingTop="8dp" android:paddingBottom="12dp"
            android:layout_marginBottom="12dp" android:visibility="gone">

            <TextView android:id="@+id/lbl_farmer_name" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_farmer_name" android:textSize="12sp" android:textColor="#64748B"
                android:layout_marginTop="8dp" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_farmer_name" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_farmer_name" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="Enter full name" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_farmer_mobile" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_farmer_mobile" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_farmer_mobile" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_farmer_mobile" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="10-digit mobile number"
                    android:inputType="phone" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_farmer_app_no" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_farmer_app_no" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <!-- Farmer Verified Status — shown when OTP verified -->
            <TextView
                android:id="@+id/lbl_farmer_verified"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#16A34A"
                android:textStyle="bold"
                android:paddingStart="4dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>
            <!-- Farmer Verification Status field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/farmer_verification"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:layout_marginBottom="4dp"/>

            <FrameLayout
                android:id="@+id/frame_et_farmer_verification_status"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp">
                <EditText
                    android:id="@+id/et_farmer_verification_status"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Not verified"
                    android:textSize="14sp"
                    android:focusable="false"
                    android:clickable="false"
                    android:cursorVisible="false"
                    android:background="@drawable/input_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:gravity="center_vertical"
                    android:textColor="#1A1A1A"/>
            </FrameLayout>



            <FrameLayout android:id="@+id/frame_et_farmer_app_no" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background">
                <EditText android:id="@+id/et_farmer_app_no" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="Enter application number" android:padding="12dp"/>
            </FrameLayout>
        </LinearLayout>

        <!-- ══ SECTION 5: Field Parameters ══ -->
        <LinearLayout android:id="@+id/section_header_5"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal" android:background="@drawable/section_header_collapsed"
            android:padding="14dp" android:gravity="center_vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/section_observations" android:textSize="15sp" android:textStyle="bold" android:textColor="#0F172A"/>
            <ImageView android:id="@+id/ic_check_5" android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_check_white" android:background="@drawable/circle_green"
                android:visibility="gone" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/arrow_5" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▼" android:textColor="#64748B" android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/section_body_5"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/section_card_bg"
            android:paddingLeft="12dp" android:paddingRight="12dp"
            android:paddingTop="8dp" android:paddingBottom="12dp"
            android:layout_marginBottom="12dp" android:visibility="gone">

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_field_area_polygon" android:textSize="12sp" android:textColor="#2563EB"
                android:textStyle="bold" android:layout_marginTop="8dp" android:layout_marginBottom="4dp"/>
            <FrameLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_field_area_polygon" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="Auto-filled from map polygon"
                    android:focusable="false" android:clickable="false"
                    android:textColor="#0F172A" android:textColorHint="#94A3B8" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_sowing_date" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_sowing_date" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_sowing_date" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_sowing_date" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="Tap to select date"
                    android:focusable="false" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_expected_harvest" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_expected_harvest" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_expected_harvest" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_expected_harvest" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="Tap to select date"
                    android:focusable="false" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_plant_count_sqm" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_fresh_biomass" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_plant_count_sqm" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_plant_count_sqm" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="e.g. 6" android:inputType="number" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_row_spacing" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_fresh_grain" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_row_spacing" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_row_spacing" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="e.g. 30" android:inputType="numberDecimal" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_ridge_distance" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_dry_grain" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_ridge_distance" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_ridge_distance" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="e.g. 60" android:inputType="numberDecimal" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_num_irrigations" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_moisture_pct" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_num_irrigations" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_num_irrigations" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="e.g. 3" android:inputType="number" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_fertilizer_kg_ha" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_yield_kg_per_ha" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_fertilizer_kg_ha" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background">
                <EditText android:id="@+id/et_fertilizer_kg_ha" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="e.g. 120" android:inputType="numberDecimal" android:padding="12dp"/>
            </FrameLayout>
        </LinearLayout>

        <!-- ══ SECTION 6: Pest & Disease ══ -->
        <LinearLayout android:id="@+id/section_header_6"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal" android:background="@drawable/section_header_collapsed"
            android:padding="14dp" android:gravity="center_vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/section_observations" android:textSize="15sp" android:textStyle="bold" android:textColor="#0F172A"/>
            <ImageView android:id="@+id/ic_check_6" android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_check_white" android:background="@drawable/circle_green"
                android:visibility="gone" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/arrow_6" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▼" android:textColor="#64748B" android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/section_body_6"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/section_card_bg"
            android:paddingLeft="12dp" android:paddingRight="12dp"
            android:paddingTop="8dp" android:paddingBottom="12dp"
            android:layout_marginBottom="12dp" android:visibility="gone">

            <CheckBox android:id="@+id/cb_pest_incidents" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="@string/field_observations"
                android:textColor="#0F172A" android:layout_marginTop="8dp" android:layout_marginBottom="12dp"/>

            <TextView android:id="@+id/lbl_pest_name" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_observations" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_pest_name" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background">
                <EditText android:id="@+id/et_pest_name" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="Enter pest or disease name" android:padding="12dp"/>
            </FrameLayout>
        </LinearLayout>

        <!-- ══ SECTION 7: Yield Measurements ══ -->
        <LinearLayout android:id="@+id/section_header_7"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal" android:background="@drawable/section_header_collapsed"
            android:padding="14dp" android:gravity="center_vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/section_yield" android:textSize="15sp" android:textStyle="bold" android:textColor="#0F172A"/>
            <ImageView android:id="@+id/ic_check_7" android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_check_white" android:background="@drawable/circle_green"
                android:visibility="gone" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/arrow_7" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▼" android:textColor="#64748B" android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/section_body_7"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/section_card_bg"
            android:paddingLeft="12dp" android:paddingRight="12dp"
            android:paddingTop="8dp" android:paddingBottom="12dp"
            android:layout_marginBottom="12dp" android:visibility="gone">

            <TextView android:id="@+id/lbl_plant_weight" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_fresh_biomass" android:textSize="12sp" android:textColor="#64748B"
                android:layout_marginTop="8dp" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_plant_weight" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_plant_weight" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="e.g. 450" android:inputType="numberDecimal" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_tuber_count" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_fresh_grain" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_tuber_count" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_tuber_count" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="e.g. 8" android:inputType="number" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_tuber_weight" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_dry_grain" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_tuber_weight" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_tuber_weight" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="e.g. 320" android:inputType="numberDecimal" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_plant_weight_grain" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_fresh_grain" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_plant_weight_grain" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_plant_weight_grain" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="e.g. 280" android:inputType="numberDecimal" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_grain_weight" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_dry_grain" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_grain_weight" android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_grain_weight" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="e.g. 180" android:inputType="numberDecimal" android:padding="12dp"/>
            </FrameLayout>

            <TextView android:id="@+id/lbl_remarks" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/field_remarks" android:textSize="12sp" android:textColor="#64748B" android:layout_marginBottom="4dp"/>
            <FrameLayout android:id="@+id/frame_et_remarks" android:layout_width="match_parent" android:layout_height="96dp"
                android:background="@drawable/input_background" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_remarks" android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@android:color/transparent" android:hint="Any additional observations or notes"
                    android:gravity="top" android:padding="12dp"/>
