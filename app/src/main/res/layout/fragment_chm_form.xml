                    android:text="📍 GPS: " android:textColor="#16A34A" android:textStyle="bold"/>
                <TextView android:id="@+id/tv_gps_coords" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Acquiring..." android:textColor="#64748B"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
