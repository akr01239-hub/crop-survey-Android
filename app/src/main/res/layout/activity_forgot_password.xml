<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#F7F9FB">

    <!-- Top bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp" android:paddingTop="40dp"
        android:background="#FFFFFF" android:gravity="center_vertical">
        <ImageButton android:id="@+id/btn_back" android:layout_width="40dp" android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Forgot Password" android:textSize="17sp" android:textStyle="bold"
            android:textColor="#0F172A" android:layout_marginStart="8dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="24dp">

            <!-- Step indicator -->
            <LinearLayout android:id="@+id/layout_steps" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:gravity="center" android:layout_marginBottom="24dp">
                <TextView android:id="@+id/tv_step1_dot" android:layout_width="28dp" android:layout_height="28dp"
                    android:text="1" android:gravity="center" android:textSize="12sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:background="@drawable/step_dot_active"/>
                <View android:layout_width="40dp" android:layout_height="2dp" android:id="@+id/step_line_1" android:background="#CBD5E1"/>
                <TextView android:id="@+id/tv_step2_dot" android:layout_width="28dp" android:layout_height="28dp"
                    android:text="2" android:gravity="center" android:textSize="12sp" android:textStyle="bold"
                    android:textColor="#94A3B8" android:background="@drawable/step_dot_inactive"/>
                <View android:layout_width="40dp" android:layout_height="2dp" android:id="@+id/step_line_2" android:background="#CBD5E1"/>
                <TextView android:id="@+id/tv_step3_dot" android:layout_width="28dp" android:layout_height="28dp"
                    android:text="3" android:gravity="center" android:textSize="12sp" android:textStyle="bold"
                    android:textColor="#94A3B8" android:background="@drawable/step_dot_inactive"/>
            </LinearLayout>

            <!-- Error banner -->
            <TextView android:id="@+id/tv_error" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="#FEF2F2"
                android:padding="12dp" android:textColor="#DC2626" android:textSize="13sp"
                android:layout_marginBottom="12dp" android:visibility="gone"/>

            <ProgressBar android:id="@+id/progress_bar" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:layout_gravity="center"
                android:visibility="gone" android:layout_marginBottom="8dp"/>

            <!-- ── Step 1: Phone ─────────────────────────────────────────── -->
            <LinearLayout android:id="@+id/layout_phone_step" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Enter your registered phone number to get started."
                    android:textColor="#64748B" android:textSize="14sp" android:layout_marginBottom="24dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Phone Number" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="#0F172A" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/et_phone" android:layout_width="match_parent"
                    android:layout_height="50dp" android:hint="+91 10-digit number"
                    android:inputType="phone" android:background="@drawable/input_background"
                    android:padding="14dp" android:layout_marginBottom="24dp"
                    android:textColor="#0F172A" android:textColorHint="#94A3B8"/>

                <Button android:id="@+id/btn_next_phone" android:layout_width="match_parent"
                    android:layout_height="52dp" android:text="CONTINUE"
                    android:backgroundTint="#2563EB" android:textColor="#FFFFFF" android:textStyle="bold"/>
            </LinearLayout>

            <!-- ── Step 2: PAN Verification ──────────────────────────────── -->
            <LinearLayout android:id="@+id/layout_pan_step" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:background="#EFF6FF"
                    android:padding="14dp" android:layout_marginBottom="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔒" android:textSize="18sp" android:layout_marginEnd="10dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Verify Your Identity" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="#1E40AF"/>
                        <TextView android:id="@+id/tv_pan_hint" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enter the PAN number linked to your account to verify."
                            android:textColor="#3B82F6" android:textSize="12sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PAN Number" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="#0F172A" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/et_pan" android:layout_width="match_parent"
                    android:layout_height="50dp" android:hint="e.g. ABCDE1234F"
                    android:inputType="textCapCharacters" android:background="@drawable/input_background"
                    android:padding="14dp" android:layout_marginBottom="6dp"
                    android:textColor="#0F172A" android:textColorHint="#94A3B8"
                    android:maxLength="10"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PAN is used only to verify your identity — it won't be displayed anywhere."
                    android:textColor="#94A3B8" android:textSize="11sp" android:layout_marginBottom="24dp"/>

                <Button android:id="@+id/btn_verify_pan" android:layout_width="match_parent"
                    android:layout_height="52dp" android:text="VERIFY PAN"
                    android:backgroundTint="#2563EB" android:textColor="#FFFFFF" android:textStyle="bold"/>
            </LinearLayout>

            <!-- ── Step 3: New Password ──────────────────────────────────── -->
            <LinearLayout android:id="@+id/layout_password_step" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:background="#F0FDF4"
                    android:padding="14dp" android:layout_marginBottom="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✅" android:textSize="18sp" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Identity verified! Set your new password below."
                        android:textColor="#15803D" android:textSize="13sp" android:textStyle="bold"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="New Password" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="#0F172A" android:layout_marginBottom="6dp"/>
                <RelativeLayout android:layout_width="match_parent" android:layout_height="50dp"
                    android:layout_marginBottom="16dp">
                    <EditText android:id="@+id/et_new_password" android:layout_width="match_parent"
                        android:layout_height="match_parent" android:hint="Min 6 characters"
                        android:inputType="textPassword" android:background="@drawable/input_background"
                        android:padding="14dp" android:paddingEnd="70dp"
                        android:textColor="#0F172A" android:textColorHint="#94A3B8"/>
                    <TextView android:id="@+id/btn_show_password" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Show"
                        android:textColor="#2563EB" android:textStyle="bold" android:textSize="13sp"
                        android:layout_alignParentEnd="true" android:layout_centerVertical="true"
                        android:paddingEnd="14dp" android:clickable="true" android:focusable="true"/>
                </RelativeLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Confirm Password" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="#0F172A" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/et_confirm_password" android:layout_width="match_parent"
                    android:layout_height="50dp" android:hint="Re-enter password"
                    android:inputType="textPassword" android:background="@drawable/input_background"
                    android:padding="14dp" android:layout_marginBottom="24dp"
                    android:textColor="#0F172A" android:textColorHint="#94A3B8"/>

                <Button android:id="@+id/btn_reset_password" android:layout_width="match_parent"
                    android:layout_height="52dp" android:text="RESET PASSWORD"
                    android:backgroundTint="#16A34A" android:textColor="#FFFFFF" android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>