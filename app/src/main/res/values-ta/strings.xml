    <string name="guide_disabled_toast">வழிகாட்டி அணைக்கப்பட்டது. மீண்டும் இயக்க 🤖 தட்டவும்।</string>


    <!-- AI GUIDE STRINGS -->
    <string name="guide_slide1_title">கிருஷி சர்வேக்ஷணுக்கு வரவேற்கிறோம்</string>
    <string name="guide_slide1_body">இந்த வழிகாட்டி ஆப்பை எவ்வாறு பயன்படுத்துவது மற்றும் முதல் கணக்கெடுப்பை எவ்வாறு முடிப்பது என்பதை விளக்கும்।\n\nஒவ்வொரு பக்கத்தையும் கவனமாகப் படியுங்கள் — 2 நிமிடங்களுக்கும் குறைவு.</string>
    <string name="guide_slide2_title">ஒரு கணக்கு — ஒரு சாதனம்</string>
    <string name="guide_slide2_body">⚠️ உங்கள் கணக்கு முதல் சாதனத்தில் பூட்டப்படும்।\n\n• இரண்டாம் சாதனில் உள்நுழைந்தால் முதல் சாதனம் வெளியேறும்.\n• ஒரே நேரத்தில் 2 சாதனங்கள் பயன்படுத்த முடியாது.</string>
    <string name="guide_slide3_title">போலி GPS பயன்படுத்தாதீர்கள்</string>
    <string name="guide_slide3_body">ஆப் போலி இடம் கண்டறியும்.\n\n• போலி இடம் கண்டறிந்தால் ஆப் உடனே மூடும்.\n• போலி GPS கணக்கெடுப்புகள் நிராகரிக்கப்படும்.</string>
    <string name="guide_slide4_title">கணக்கெடுப்பு வகைகள்</string>
    <string name="guide_slide4_body">ஆப்பில் 3 கணக்கெடுப்பு வகைகள் உள்ளன:\n\n🟢  CLS — பயிர் இழப்பு கணக்கெடுப்பு\n🔵  CHM — பயிர் ஆரோக்கிய கண்காணிப்பு\n🟠  CCE — பயிர் வெட்டு சோதனை</string>
    <string name="guide_slide5_title">புகைப்படங்கள் முக்கியம்</string>
    <string name="guide_slide5_body">தேவையான புகைப்படங்கள் அனைத்தையும் சமர்ப்பிக்கும் முன் எடுக்க வேண்டும்.\n\n• புகைப்படங்கள் தானாக GPS குறிக்கப்படும்.\n• ஆப் கேமராவில் எடுக்கவும் — கேலரியிலிருந்து இறக்குமதி செய்யாதீர்கள்.</string>
    <string name="guide_slide6_title">வரைவு → சமர்ப்பிப்பு → அனுமதி</string>
    <string name="guide_slide6_body">கணக்கெடுப்பு இவ்வாறு நிறைவடைகிறது:\n\n1️⃣  படிவம் நிரப்பு + புகைப்படம் எடு\n2️⃣  Save Draft அழுத்து\n3️⃣  தயாரானதும் Submit அழுத்து\n4️⃣  QC மதிப்பாய்வுக்கு செல்கிறது\n5️⃣  Approved ✅ அல்லது Rejected ❌</string>
    <string name="guide_slide6_btn">புரிந்தது! தொடங்குவோம்</string>
    <string name="guide_step0_title">👋 வணக்கம்! நான் உங்கள் AI கணக்கெடுப்பு வழிகாட்டி</string>
    <string name="guide_step0_msg">முதல் கணக்கெடுப்பை தொடக்கத்திலிருந்து முடிக்க உதவுவேன்.</string>
    <string name="guide_step0_tip">💡 குறிப்பு: CLS = பயிர் இழப்பு கணக்கெடுப்பு. முதலில் CLS தொடங்குங்கள்.</string>
    <string name="guide_step0_action">CLS தொடங்கு →</string>
    <string name="guide_step1_title">📋 கணக்கெடுப்பு வகை தேர்வு செய்யுங்கள்</string>
    <string name="guide_step1_msg">CLS அட்டையை தட்டுங்கள்.</string>
    <string name="guide_step1_tip">💡 குறிப்பு: அனைத்து வகைகளும் ஒரே ஓட்டம் — படிவம் + புகைப்படம் + சமர்ப்பிப்பு.</string>
    <string name="guide_step1_action">புரிந்தது →</string>
    <string name="guide_step2_title">👨‍🌾 விவசாயி சரிபார்ப்பு</string>
    <string name="guide_step2_msg">மொபைல் மற்றும் OTP மூலம் விவசாயியின் அடையாளத்தை சரிபார்க்கவும்.\n\nவிவசாயி இல்லாவிட்டால் SKIP அழுத்துங்கள்.</string>
    <string name="guide_step2_tip">💡 குறிப்பு: சரிபார்க்கப்பட்ட கணக்கெடுப்புகள் விரைவாக செயலாக்கப்படும்.</string>
    <string name="guide_step2_action">புரிந்தது →</string>
    <string name="guide_step3_title">✅ சரிபார்க்கப்பட்டது!</string>
    <string name="guide_step3_msg">விவசாயியின் தொலைபேசி உறுதிப்படுத்தப்பட்டது.</string>
    <string name="guide_step3_tip">💡 குறிப்பு: சமர்ப்பிக்கும் முன்பும் சரிபார்க்கலாம்.</string>
    <string name="guide_step3_action">புரிந்தது →</string>
    <string name="guide_step4_title">🗺️ வயல் எல்லை வரையுங்கள்</string>
    <string name="guide_step4_msg">வரைபடத்தில் குறைந்தது 3 புள்ளிகள் தட்டுங்கள்.</string>
    <string name="guide_step4_tip">💡 குறிப்பு: தவறு ஆனால் DELETE அழுத்துங்கள்.</string>
    <string name="guide_step4_action">புரிந்தது →</string>
    <string name="guide_step5_title">📝 கணக்கெடுப்பு படிவம் நிரப்புங்கள்</string>
    <string name="guide_step5_msg">* குறிக்கப்பட்ட அனைத்து கட்டாய புலங்களையும் நிரப்புங்கள்.</string>
    <string name="guide_step5_tip">💡 குறிப்பு: எப்போதும் \'Save Draft\' அழுத்தலாம்.</string>
    <string name="guide_step5_action">புரிந்தது →</string>
    <string name="guide_step6_title">📅 அடிப்படை தகவல் பிரிவு</string>
    <string name="guide_step6_msg">நிரப்புங்கள்:\n• ஆண்டு\n• பருவம் (கரீஃப் / ரபி / ஜாயத்)\n• திட்டம்</string>
    <string name="guide_step6_tip">💡 குறிப்பு: ஆண்டு தானாக நிரப்பப்படும்.</string>
    <string name="guide_step6_action">புரிந்தது →</string>
    <string name="guide_step7_title">📍 இடம் பிரிவு</string>
    <string name="guide_step7_msg">மாநிலம் → மாவட்டம் → தாலுகா → கிராமம் தேர்வு செய்யுங்கள்.</string>
    <string name="guide_step7_tip">💡 குறிப்பு: கிராமம் இல்லாவிட்டால் Gram Panchayat புலத்தில் எழுதுங்கள்.</string>
    <string name="guide_step7_action">புரிந்தது →</string>
    <string name="guide_step8_title">🌾 பயிர் விவரங்கள் பிரிவு</string>
    <string name="guide_step8_msg">பயிர் வகை, ரகம், நிலை மற்றும் நீர்ப்பாசன வகை தேர்வு செய்யுங்கள்.</string>
    <string name="guide_step8_tip">💡 குறிப்பு: பயிர் தற்போது இருக்கும் நிலையை தேர்வு செய்யுங்கள்.</string>
    <string name="guide_step8_action">புரிந்தது →</string>
    <string name="guide_step9_title">📸 இப்போது புகைப்படங்கள்</string>
    <string name="guide_step9_msg">PHOTOS தாவலை தட்டுங்கள். Required ✦ புகைப்படங்கள் சமர்ப்பிக்கும் முன் எடுக்க வேண்டும்.</string>
    <string name="guide_step9_tip">💡 குறிப்பு: புகைப்படங்கள் தானாக GPS குறிக்கப்படும்.</string>
    <string name="guide_step9_action">புரிந்தது →</string>
    <string name="guide_step10_title">📷 தேவையான புகைப்படங்கள் எடுங்கள்</string>
    <string name="guide_step10_msg">ஒவ்வொரு slot அருகே CAPTURE அழுத்துங்கள்.</string>
    <string name="guide_step10_tip">💡 குறிப்பு: மங்கலாக இருந்தால் RETAKE அழுத்துங்கள்.</string>
    <string name="guide_step10_action">புரிந்தது →</string>
    <string name="guide_step11_title">💾 வரைவை சேமிக்கவும்</string>
    <string name="guide_step11_msg">SAVE DRAFT அழுத்துங்கள்.\n• பிறகு தொடரலாம்\n• தரவு இழக்க மாட்டீர்கள்</string>
    <string name="guide_step11_tip">💡 குறிப்பு: கைமுறை சேமிப்பு மிகவும் நம்பகமானது.</string>
    <string name="guide_step11_action">புரிந்தது →</string>
    <string name="guide_step12_title">🎉 சமர்ப்பிக்க தயார்!</string>
    <string name="guide_step12_msg">SUBMIT → அழுத்துங்கள்.\n\nசமர்ப்பித்த பின்:\n• QC குழு 24-48 மணி நேரத்தில் மதிப்பாய்வு செய்யும்\n• Approved ✅ அல்லது Rejected ❌ காட்டும்</string>
    <string name="guide_step12_tip">💡 Dashboard இல் 🤖 Guide பொத்தான் அழுத்தி மீண்டும் படிக்கலாம்.</string>
    <string name="guide_step12_action">சமர்ப்பி மற்றும் முடி 🎉</string>
    <string name="guide_step_progress">படி %1$d / %2$d</string>
    <string name="guide_turn_off_title">AI வழிகாட்டியை அணைக்கவும்?</string>
    <string name="guide_turn_off_msg">வழிகாட்டி காட்டுவது நிறுத்தப்படும். Dashboard → Guide பொத்தானில் மீண்டும் இயக்கவும்.</string>
    <string name="guide_turn_off_confirm">அணை</string>
    <string name="guide_keep_on">இயக்கில் வை</string>
    <string name="guide_skip">வழிகாட்டியை தவிர்</string>

